      "keywords": ["SEC", "FTC", "FDA", "approval", "regulatory", "investigation", "compliance", "fine", "penalty"],
      "patterns": [
        "(SEC|FTC|FDA|DOJ) (files?|investigates?|approves?)",
        "regulatory (approval|action|fine)",
        "under investigation",
        "receives? (approval|clearance)"
      ],
      "examples": [
        "FDA approves Pfizer's COVID-19 vaccine for emergency use",
        "FTC investigates Amazon for anti-competitive practices",
        "SEC charges Tesla CEO with securities fraud"
      ],
      "market_impact": "HIGH",
      "typical_price_reaction": "±5-20%"
    },
    {
      "id": 4,
      "name": "EXECUTIVE_CHANGE",
