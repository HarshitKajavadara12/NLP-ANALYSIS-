    {
      "id": 11,
      "name": "ECONOMIC_INDICATOR",
      "description": "Macroeconomic data releases",
      "keywords": ["GDP", "inflation", "CPI", "unemployment", "Fed", "interest rate", "jobs report"],
      "patterns": [
