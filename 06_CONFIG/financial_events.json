{
  "events": [
    {
      "id": 0,
      "name": "EARNINGS_ANNOUNCEMENT",
      "description": "Quarterly or annual financial results release",
      "keywords": ["earnings", "quarterly results", "EPS", "beat estimates", "miss expectations", "guidance", "revenue", "profit"],
      "patterns": [
        "Q[1-4] \\d{4} earnings",
        "beats? (earnings|EPS|estimates?)",
        "reports? (quarterly|annual) (results?|earnings)",
        "guidance for",
        "announces? (results?|earnings)"
      ],
      "examples": [
        "Apple reports Q1 earnings beat with record iPhone sales",
        "Tesla misses EPS estimates, guides lower for next quarter",
        "Microsoft announces quarterly results exceeding expectations"
      ],
      "market_impact": "HIGH",
      "typical_price_reaction": "±5-15%"
    },
    {
      "id": 1,
      "name": "MERGER_ACQUISITION",
      "description": "Company mergers, acquisitions, takeovers",
      "keywords": ["merger", "acquisition", "M&A", "acquires", "buys", "takeover", "buyout", "purchase"],
      "patterns": [
        "(acquires?|purchases?|buys) .+ for \\$",
        "merger (with|between)",
        "takeover (bid|offer)",
        "\\$\\d+[BM] (deal|acquisition)"
      ],
      "examples": [
        "Microsoft acquires Activision Blizzard for $69 billion",
        "Broadcom to buy VMware in $61 billion deal",
        "Amazon announces acquisition of MGM Studios"
      ],
      "market_impact": "HIGH",
      "typical_price_reaction": "±10-30%"
    },
    {
      "id": 2,
      "name": "PRODUCT_LAUNCH",
      "description": "New product or service releases",
      "keywords": ["launches", "unveils", "introduces", "releases", "announces new", "debuts", "rolls out"],
      "patterns": [
        "(launches?|unveils?|introduces?) (new|latest)",
        "announces? (new|upcoming) (product|service)",
        "rolls? out",
        "debuts?"
      ],
      "examples": [
        "Apple unveils new iPhone 15 with USB-C",
        "Tesla launches Cybertruck after years of delays",
        "Google introduces Gemini AI to compete with ChatGPT"
      ],
      "market_impact": "MEDIUM",
      "typical_price_reaction": "±3-8%"
    },
    {
      "id": 3,
      "name": "REGULATORY_ACTION",
