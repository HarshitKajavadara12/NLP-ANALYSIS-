      "keywords": ["CEO", "CFO", "resigns", "steps down", "appoints", "hires", "names", "succession"],
      "patterns": [
        "(CEO|CFO|COO|CTO) (resigns?|steps down|departs?)",
        "(appoints?|names?|hires?) .+ as (CEO|CFO)",
